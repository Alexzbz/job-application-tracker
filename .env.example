# =============================================================================
# 简历投递管理系统 - 环境变量配置
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB 数据库配置（生产环境必须配置）
# -----------------------------------------------------------------------------
# 获取方式：
# 1. 访问 https://www.mongodb.com/cloud/atlas 注册 MongoDB Atlas（免费）
# 2. 创建免费集群（Free Tier - 512MB）
# 3. 创建数据库用户，获取连接字符串
# 4. 将连接字符串中的 <password> 替换为实际密码
#
# 示例：mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/job-tracker?retryWrites=true&w=majority
# 注意：不配置将使用本地文件存储（data/ 目录），不适合生产环境
MONGODB_URI=

# -----------------------------------------------------------------------------
# 百度 OCR API 凭证（可选，用于图片识别职位信息）
# -----------------------------------------------------------------------------
# 获取方式：
# 1. 访问 https://ai.baidu.com/ 注册百度智能云账号
# 2. 创建应用，选择"文字识别"服务
# 3. 获取 API Key 和 Secret Key
#
# 注意：不配置将无法使用"扫描图片"功能，但不影响其他功能
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
